# Copy this file to .env (for local dev with `vercel dev`) and fill in real values.
# In production, set these as Environment Variables in the Vercel dashboard instead.

# --- Gmail (for the contact form) ---
# GMAIL_USER: the Gmail address that will SEND the email (can be the same as the one receiving it)
GMAIL_USER=youraddress@gmail.com

# GMAIL_APP_PASSWORD: a 16-character Gmail "App Password" — NOT your normal Gmail password.
# Generate one at https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be turned on for your Google account first.)
GMAIL_APP_PASSWORD=Honey@0897

# CONTACT_TO_EMAIL: the address that should RECEIVE contact form messages.
# Optional — defaults to GMAIL_USER if not set.
CONTACT_TO_EMAIL=sreecharanreddy286@gmail.com

# --- Admin upload ---
# ADMIN_PASSWORD: the password you'll type into the "Admin" panel on the site to upload a new resume.
# Pick something only you know — this is the only thing protecting the upload endpoint.
ADMIN_PASSWORD=choose-a-strong-password-here

# --- Vercel Blob (file storage for the resume PDF) ---
# BLOB_READ_WRITE_TOKEN: created automatically when you add the "Blob" storage integration
# in your Vercel project dashboard (Storage tab -> Create Database -> Blob).
# Vercel will offer to add this env var for you automatically — just confirm it.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxx
